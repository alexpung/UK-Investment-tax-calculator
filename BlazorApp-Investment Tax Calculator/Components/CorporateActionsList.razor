@using InvestmentTaxCalculator.Model
@using InvestmentTaxCalculator.Model.TaxEvents
@using InvestmentTaxCalculator.Model.Interfaces
@using InvestmentTaxCalculator.Services

@inject ITradeAndCorporateActionList _taxEventLists
@inject ToastService _toastService

<div class="card mt-4">
    <div class="card-header">
        <h3>Corporate Actions and Events History</h3>
    </div>
    <div class="card-body">
        <RadzenDataGrid @ref="_grid" TItem="CorporateAction" Data="@_taxEventLists.CorporateActions"
                        AllowPaging="true" PageSize="10" AllowSorting="true" AllowColumnResize="true" class="w-100">
            <Columns>
                <RadzenDataGridColumn TItem="CorporateAction" Property="@nameof(CorporateAction.Date)" Title="Date" FormatString="{0:d}" Width="120px" />
                <RadzenDataGridColumn TItem="CorporateAction" Property="@nameof(CorporateAction.AssetName)" Title="Asset" Width="150px" />
                <RadzenDataGridColumn TItem="CorporateAction" Property="@nameof(CorporateAction.Reason)" Title="Reason/Description" />
                <RadzenDataGridColumn TItem="CorporateAction" Title="Actions" Width="220px" TextAlign="TextAlign.Center" Sortable="false" Filterable="false">
                    <Template Context="action">
                        <div class="d-flex gap-2 justify-content-center">
                            <RadzenButton Icon="edit" ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.Small" Click="@(() => EditAction(action))" Text="Edit" class="flex-shrink-0" />
                            <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Size="ButtonSize.Small" Click="@(() => DeleteAction(action))" Text="Delete" class="flex-shrink-0" />
                        </div>
                    </Template>
                </RadzenDataGridColumn>
            </Columns>
        </RadzenDataGrid>
    </div>
</div>

@code {
    [Parameter] public EventCallback OnActionDeleted { get; set; }
    [Parameter] public EventCallback<CorporateAction> OnActionEdit { get; set; }

    private RadzenDataGrid<CorporateAction> _grid = default!;

    public void Refresh()
    {
        _ = _grid?.Reload();
    }

    private async Task EditAction(CorporateAction action)
    {
        await OnActionEdit.InvokeAsync(action);
    }

    private async Task DeleteAction(CorporateAction action)
    {
        if (_taxEventLists.CorporateActions.Remove(action))
        {
            _toastService.ShowInformation("Event removed.");
            Refresh();
            await OnActionDeleted.InvokeAsync();
        }
    }
}
