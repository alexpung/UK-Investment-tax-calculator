@using InvestmentTaxCalculator.Model
@using System.Globalization
@using InvestmentTaxCalculator.Services
@inherits TaxCalculationRefreshComponentBase

@inject DividendCalculationResult _dividendCalculationResult

<div class="bg-dark text-light">
    <div class="row my-4">
        <div class="col">
            <h3>Dividend Summary Report</h3>
        </div>
    </div>

    <div class="row mt-3 me-3">
        <div class="col">
            <RadzenDataGrid @ref="dividendSummaryGrid" TItem="DividendSummary" Data="@_dividendSummaries"
                            AllowGrouping="true" AllowPaging="true" PageSize="25" PageSizeOptions="@_pageSizeOptions"
                            AllowSorting="true" AllowFiltering="true" FilterMode="FilterMode.Advanced"
                            AllowColumnResize="true" class="w-100">
                <Columns>
                    <RadzenDataGridColumn TItem="DividendSummary" Property="@nameof(DividendSummary.TaxYear)" Title="Tax Year" TextAlign="TextAlign.Right" FilterMode="FilterMode.CheckBoxList" />
                    <RadzenDataGridColumn TItem="DividendSummary" Property="CountryOfOrigin.ThreeDigitCode" Title="Country of Origin" FilterMode="FilterMode.CheckBoxList" />
                    <RadzenDataGridColumn TItem="DividendSummary" Property="TotalInterestIncome.Amount" Title="Total interest income" FormatString="{0:C2}" TextAlign="TextAlign.Right">
                        <FooterTemplate>
                            Total: <b>@_dividendSummaries.Sum(d => d.TotalInterestIncome.Amount).ToString("C2", CultureInfo.CurrentCulture)</b>
                        </FooterTemplate>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="DividendSummary" Property="TotalTaxableDividend.Amount" Title="Total Taxable Dividend" FormatString="{0:C2}" TextAlign="TextAlign.Right">
                        <FooterTemplate>
                            Total: <b>@_dividendSummaries.Sum(d => d.TotalTaxableDividend.Amount).ToString("C2", CultureInfo.CurrentCulture)</b>
                        </FooterTemplate>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="DividendSummary" Property="TotalForeignTaxPaid.Amount" Title="Total Foreign Tax Paid" FormatString="{0:C2}" TextAlign="TextAlign.Right">
                        <FooterTemplate>
                            Total: <b>@_dividendSummaries.Sum(d => d.TotalForeignTaxPaid.Amount).ToString("C2", CultureInfo.CurrentCulture)</b>
                        </FooterTemplate>
                    </RadzenDataGridColumn>
                </Columns>
            </RadzenDataGrid>
        </div>
    </div>
</div>

@code {
    private RadzenDataGrid<DividendSummary>? dividendSummaryGrid;
    private List<DividendSummary> _dividendSummaries = [];
    private readonly int[] _pageSizeOptions = { 25, 50, 100 };
    private bool _initialGroupApplied;

    protected override void RefreshData()
    {
        _dividendSummaries = _dividendCalculationResult.DividendSummary.ToList();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Apply the initial grouping by tax year once the grid is rendered.
        if (!_initialGroupApplied && dividendSummaryGrid is not null)
        {
            _initialGroupApplied = true;
            dividendSummaryGrid.Groups.Add(new GroupDescriptor { Property = nameof(DividendSummary.TaxYear), Title = "Tax Year" });
            await dividendSummaryGrid.Reload();
        }
    }

    protected override Task RefreshRenderedGridsAsync() => RefreshGridAsync(dividendSummaryGrid);
}
