@using InvestmentTaxCalculator.Services.PdfExport.Sections
@using InvestmentTaxCalculator.Services.PdfExport;

<div class="bg-dark text-light">
    <div class="row">
        <div class="col">
            <h3>Export Calculation Result to PDF</h3>
        </div>
    </div>

    <div>
        <h5>Active Sections</h5>
        <p>Tick the sections to include, and use the arrows to change their order.</p>
        <div class="list-group">
            @for (int i = 0; i < PdfExportService.AllSections.Count; i++)
            {
                var index = i;
                var section = PdfExportService.AllSections[index];
                <div class="list-group-item d-flex align-items-center justify-content-between bg-dark text-light">
                    <div class="d-flex align-items-center">
                        <RadzenCheckBox TValue="bool" Value="IsSelected(section.Name)"
                                        Change="@(v => ToggleSection(section.Name, v))" Name="@($"sec_{index}")" />
                        <RadzenLabel Text="@section.Name" Component="@($"sec_{index}")" class="ms-2" />
                    </div>
                    <div class="btn-group">
                        <RadzenButton Icon="arrow_upward" Size="ButtonSize.Small" Variant="Variant.Text"
                                      Disabled="@(index == 0)" Click="@(() => MoveUp(index))" />
                        <RadzenButton Icon="arrow_downward" Size="ButtonSize.Small" Variant="Variant.Text"
                                      Disabled="@(index == PdfExportService.AllSections.Count - 1)" Click="@(() => MoveDown(index))" />
                    </div>
                </div>
            }
        </div>
    </div>
    <div class="mt-3">
        <h5>Disposal Tax Calculation Detail Settings</h5>
        <RadzenRadioButtonList @bind-Value="DisposalDetailSection.OnlyShowTaxableTrades" TValue="bool" class="d-flex flex-column gap-2">
            <Items>
                <RadzenRadioButtonListItem Value="true"
                    Text="Show trades taxable in the report years (non-taxable trades are not shown, taxable temporary non-resident trades shown when return to UK resident)" />
                <RadzenRadioButtonListItem Value="false"
                    Text="Show trades occurred in the report years (non-resident and temporary non-resident trades is also shown)" />
            </Items>
        </RadzenRadioButtonList>
    </div>

    <div class="row mt-3">
        <div class="col-md-4 mb-2">
            <RadzenButton Click="InvokeExportToPdf" ButtonStyle="ButtonStyle.Primary" Text="Export to PDF" />
        </div>
    </div>
</div>

@code {
    private bool IsSelected(string name) => PdfExportService.SelectedSections?.Contains(name) ?? false;

    private void ToggleSection(string name, bool isChecked)
    {
        var set = (PdfExportService.SelectedSections ?? []).ToHashSet();
        if (isChecked) set.Add(name);
        else set.Remove(name);
        PdfExportService.SelectedSections = [.. set];
    }

    private void MoveUp(int index)
    {
        if (index <= 0) return;
        (PdfExportService.AllSections[index - 1], PdfExportService.AllSections[index]) =
            (PdfExportService.AllSections[index], PdfExportService.AllSections[index - 1]);
    }

    private void MoveDown(int index)
    {
        if (index >= PdfExportService.AllSections.Count - 1) return;
        (PdfExportService.AllSections[index + 1], PdfExportService.AllSections[index]) =
            (PdfExportService.AllSections[index], PdfExportService.AllSections[index + 1]);
    }
}
