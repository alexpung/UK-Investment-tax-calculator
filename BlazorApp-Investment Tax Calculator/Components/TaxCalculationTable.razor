@using InvestmentTaxCalculator.Model
@using InvestmentTaxCalculator.ViewModel
@using InvestmentTaxCalculator.Model.Interfaces
@using InvestmentTaxCalculator.Model.TaxEvents
@using InvestmentTaxCalculator.Model.UkTaxModel
@using InvestmentTaxCalculator.Model.UkTaxModel.Stocks
@using InvestmentTaxCalculator.Enumerations
@using InvestmentTaxCalculator.Components
@using InvestmentTaxCalculator.Services
@inherits TaxCalculationRefreshComponentBase

@inject TradeCalculationResult tradeCalculationResult

<div class="card bg-dark text-light">
    <div class="card-header">
        <h3 class="mb-0">Disposal Calculation Summary</h3>
    </div>
    <div class="card-body">
        <RadzenTabs>
            <Tabs>
                <RadzenTabsItem Text="📊 Overview">
                    <div class="tab-content-wrapper">
                        <RadzenDataGrid @ref="overviewGrid" TItem="TradeTaxCalculationViewModel" Data="@_trades"
                                        AllowPaging="true" PageSize="25" PageSizeOptions="@_pageSizeOptions"
                                        AllowSorting="true" AllowFiltering="true" FilterMode="FilterMode.Advanced"
                                        AllowColumnResize="true" class="w-100">
                            <Columns>
                                <RadzenDataGridColumn TItem="TradeTaxCalculationViewModel" Property="@nameof(TradeTaxCalculationViewModel.TradeId)" Title="Trade ID" Width="100px" />
                                <RadzenDataGridColumn TItem="TradeTaxCalculationViewModel" Property="@nameof(TradeTaxCalculationViewModel.Date)" Title="Date" FormatString="{0:d}" Width="120px" />
                                <RadzenDataGridColumn TItem="TradeTaxCalculationViewModel" Property="@nameof(TradeTaxCalculationViewModel.AssetType)" Title="Asset Type" Width="120px" FilterMode="FilterMode.CheckBoxList" />
                                <RadzenDataGridColumn TItem="TradeTaxCalculationViewModel" Property="@nameof(TradeTaxCalculationViewModel.AssetName)" Title="Asset Name" Width="150px" FilterMode="FilterMode.CheckBoxList" />
                                <RadzenDataGridColumn TItem="TradeTaxCalculationViewModel" Property="@nameof(TradeTaxCalculationViewModel.AcquisitionOrDisposal)" Title="Acquisition/Disposal" Width="150px" FilterMode="FilterMode.CheckBoxList" />
                                <RadzenDataGridColumn TItem="TradeTaxCalculationViewModel" Property="@nameof(TradeTaxCalculationViewModel.ResidencyStatusAtTrade)" Title="Residency Status" Width="150px" FilterMode="FilterMode.CheckBoxList" />
                                <RadzenDataGridColumn TItem="TradeTaxCalculationViewModel" Property="@nameof(TradeTaxCalculationViewModel.Qty)" Title="Quantity" Width="100px" />
                                <RadzenDataGridColumn TItem="TradeTaxCalculationViewModel" Title="Gain (Loss)" Width="120px" Sortable="false">
                                    <Template Context="trade">
                                        @{ var cssClass = (trade.Gain?.Amount ?? 0m) >= 0 ? "text-success" : "text-danger"; }
                                        <span class="@cssClass fw-bold">@trade.Gain</span>
                                    </Template>
                                </RadzenDataGridColumn>
                            </Columns>
                        </RadzenDataGrid>
                    </div>
                </RadzenTabsItem>

                <RadzenTabsItem Text="🔗 Matching Details">
                    <div class="tab-content-wrapper">
                        <RadzenDataGrid @ref="matchingGrid" TItem="TradeTaxCalculationViewModel" Data="@_trades"
                                        AllowPaging="true" PageSize="25" PageSizeOptions="@_pageSizeOptions"
                                        AllowSorting="true" AllowFiltering="true" FilterMode="FilterMode.Advanced"
                                        AllowColumnResize="true" class="w-100">
                            <Columns>
                                <RadzenDataGridColumn TItem="TradeTaxCalculationViewModel" Property="@nameof(TradeTaxCalculationViewModel.Date)" Title="Date" FormatString="{0:d}" Width="120px" />
                                <RadzenDataGridColumn TItem="TradeTaxCalculationViewModel" Property="@nameof(TradeTaxCalculationViewModel.AssetName)" Title="Asset Name" Width="150px" FilterMode="FilterMode.CheckBoxList" />
                                <RadzenDataGridColumn TItem="TradeTaxCalculationViewModel" Property="@nameof(TradeTaxCalculationViewModel.Qty)" Title="Total Quantity Disposed" Width="150px" />
                                <RadzenDataGridColumn TItem="TradeTaxCalculationViewModel" Property="@nameof(TradeTaxCalculationViewModel.SameDayMatchQty)" Title="Same Day" Width="120px" />
                                <RadzenDataGridColumn TItem="TradeTaxCalculationViewModel" Property="@nameof(TradeTaxCalculationViewModel.BedAndBreakfastMatchQty)" Title="Bed &amp; Breakfast" Width="150px" />
                                <RadzenDataGridColumn TItem="TradeTaxCalculationViewModel" Property="@nameof(TradeTaxCalculationViewModel.Section104MatchQty)" Title="Section 104" Width="120px" />
                                <RadzenDataGridColumn TItem="TradeTaxCalculationViewModel" Property="@nameof(TradeTaxCalculationViewModel.CoveredShortMatchQty)" Title="Cover Short Sale" Width="150px" />
                                <RadzenDataGridColumn TItem="TradeTaxCalculationViewModel" Property="@nameof(TradeTaxCalculationViewModel.UnmatchedQty)" Title="Unmatched Shares" Width="150px" />
                            </Columns>
                        </RadzenDataGrid>
                    </div>
                </RadzenTabsItem>

                <RadzenTabsItem Text="💰 Calculation Breakdown">
                    <div class="tab-content-wrapper">
                        <RadzenDataGrid @ref="calculationGrid" TItem="TradeTaxCalculationViewModel" Data="@_trades"
                                        AllowPaging="true" PageSize="25" PageSizeOptions="@_pageSizeOptions"
                                        AllowSorting="true" AllowFiltering="true" FilterMode="FilterMode.Advanced"
                                        AllowColumnResize="true" class="w-100">
                            <Columns>
                                <RadzenDataGridColumn TItem="TradeTaxCalculationViewModel" Property="@nameof(TradeTaxCalculationViewModel.Date)" Title="Date" FormatString="{0:d}" Width="120px" />
                                <RadzenDataGridColumn TItem="TradeTaxCalculationViewModel" Property="@nameof(TradeTaxCalculationViewModel.AssetName)" Title="Asset Name" Width="150px" FilterMode="FilterMode.CheckBoxList" />
                                <RadzenDataGridColumn TItem="TradeTaxCalculationViewModel" Property="@nameof(TradeTaxCalculationViewModel.Qty)" Title="Quantity" Width="100px" />
                                <RadzenDataGridColumn TItem="TradeTaxCalculationViewModel" Property="@nameof(TradeTaxCalculationViewModel.TotalProceed)" Title="Total Proceeds" Width="150px" FormatString="{0:N2}" />
                                <RadzenDataGridColumn TItem="TradeTaxCalculationViewModel" Property="@nameof(TradeTaxCalculationViewModel.TotalAllowableCost)" Title="Allowable Cost" Width="150px" FormatString="{0:N2}" />
                                <RadzenDataGridColumn TItem="TradeTaxCalculationViewModel" Property="@nameof(TradeTaxCalculationViewModel.ContractValue)" Title="Contract Value (Futures)" Width="180px" FormatString="{0:N2}" />
                                <RadzenDataGridColumn TItem="TradeTaxCalculationViewModel" Title="Gain (Loss)" Width="150px" Sortable="false">
                                    <Template Context="trade">
                                        @{ var cssClass = (trade.Gain?.Amount ?? 0m) >= 0 ? "text-success" : "text-danger"; }
                                        <span class="@cssClass fw-bold">@trade.Gain</span>
                                    </Template>
                                </RadzenDataGridColumn>
                            </Columns>
                        </RadzenDataGrid>
                    </div>
                </RadzenTabsItem>
            </Tabs>
        </RadzenTabs>
    </div>
</div>

<style>
    .tab-content-wrapper {
        padding: 1rem 0;
    }

    .card-header h3 {
        font-size: 1.5rem;
        font-weight: 600;
    }
</style>

@code {
    private RadzenDataGrid<TradeTaxCalculationViewModel>? overviewGrid;
    private RadzenDataGrid<TradeTaxCalculationViewModel>? matchingGrid;
    private RadzenDataGrid<TradeTaxCalculationViewModel>? calculationGrid;
    private List<TradeTaxCalculationViewModel> _trades = [];
    private readonly int[] _pageSizeOptions = { 25, 50, 100 };

    protected override void RefreshData()
    {
        _trades = tradeCalculationResult.CalculatedTrade
            .Select(trade => new TradeTaxCalculationViewModel(trade))
            .ToList();
    }

    protected override async Task RefreshRenderedGridsAsync()
    {
        await RefreshGridAsync(overviewGrid);
        await RefreshGridAsync(matchingGrid);
        await RefreshGridAsync(calculationGrid);
    }
}
