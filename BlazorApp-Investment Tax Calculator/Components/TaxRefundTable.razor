@using InvestmentTaxCalculator.Model
@using InvestmentTaxCalculator.ViewModel
@using InvestmentTaxCalculator.Model.Interfaces
@using InvestmentTaxCalculator.Model.TaxEvents
@using InvestmentTaxCalculator.Model.UkTaxModel
@using InvestmentTaxCalculator.Model.UkTaxModel.Stocks
@using InvestmentTaxCalculator.Enumerations
@using InvestmentTaxCalculator.Components
@using InvestmentTaxCalculator.Services
@using InvestmentTaxCalculator.Model.UkTaxModel.Options;
@inherits TaxCalculationRefreshComponentBase

@inject TradeCalculationResult tradeCalculationResult

<div class="bg-dark text-light">
    <div class="row my-4">
        <div class="col">
            <h3>Tax refund</h3>
            <p>
                This indicates overpaid tax resulting from an open short option position held across tax years.
                The refund amount represents a reduction in disposal proceeds upon option settlement, or an increase in the allowable cost if the short option is subsequently repurchased.
                In both instances, the actual reclaimable tax should be manually calculated based on your marginal tax rate for the relevant tax year.
            </p>
        </div>
    </div>
        <div class="col">
            <RadzenDataGrid @ref="taxRefundGrid" TItem="TaxRepay" Data="@_trades"
                            AllowPaging="true" PageSize="25" PageSizeOptions="@_pageSizeOptions"
                            AllowSorting="true" AllowFiltering="true" FilterMode="FilterMode.Advanced"
                            AllowColumnResize="true" class="w-100">
                <Columns>
                    <RadzenDataGridColumn TItem="TaxRepay" Property="@nameof(TaxRepay.TaxYear)" Title="Tax Year" FilterMode="FilterMode.CheckBoxList" />
                    <RadzenDataGridColumn TItem="TaxRepay" Property="@nameof(TaxRepay.RefundAmount)" Title="Refund Amount" />
                    <RadzenDataGridColumn TItem="TaxRepay" Property="@nameof(TaxRepay.Reason)" Title="Reason" />
                </Columns>
            </RadzenDataGrid>
        </div>
</div>

@code {
    private RadzenDataGrid<TaxRepay>? taxRefundGrid;
    private List<TaxRepay> _trades = [];
    private readonly int[] _pageSizeOptions = { 25, 50, 100 };

    protected override void RefreshData()
    {
        _trades = tradeCalculationResult.CalculatedTrade
            .OfType<OptionTradeTaxCalculation>()
            .SelectMany(trade => trade.TaxRepayList)
            .ToList();
    }

    protected override Task RefreshRenderedGridsAsync() => RefreshGridAsync(taxRefundGrid);
}
