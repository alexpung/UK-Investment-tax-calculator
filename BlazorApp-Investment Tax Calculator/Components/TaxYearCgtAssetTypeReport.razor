@using InvestmentTaxCalculator.Model
@using InvestmentTaxCalculator.Services
@inherits TaxCalculationRefreshComponentBase

@inject TaxYearCgtByTypeReportService _taxYearCgtByTypeReportService

<div class="bg-dark text-light">
    <div class="row my-4">
        <div class="col">
            <h3>Tax Year CGT by Type Report</h3>
        </div>
    </div>

    <div class="row mt-3 me-3">
        <div class="col">
            <RadzenDataGrid @ref="taxYearCgtByTypeReportGrid" TItem="TaxYearCgtByTypeReport" Data="@_taxYearCgtByTypeReports"
                            AllowPaging="true" PageSize="25" PageSizeOptions="@_pageSizeOptions"
                            AllowSorting="true" AllowFiltering="true" FilterMode="FilterMode.Advanced"
                            AllowColumnResize="true" class="w-100">
                <Columns>
                    <RadzenDataGridColumn TItem="TaxYearCgtByTypeReport" Property="@nameof(TaxYearCgtByTypeReport.TaxYear)" Title="Tax Year" TextAlign="TextAlign.Right" FilterMode="FilterMode.CheckBoxList" />
                    <RadzenDataGridColumn TItem="TaxYearCgtByTypeReport" Title="Listed Shares">
                        <Columns>
                            <RadzenDataGridColumn TItem="TaxYearCgtByTypeReport" Property="@nameof(TaxYearCgtByTypeReport.ListedSecurityNumberOfDisposals)" Title="Number of Disposals" TextAlign="TextAlign.Right" />
                            <RadzenDataGridColumn TItem="TaxYearCgtByTypeReport" Property="@nameof(TaxYearCgtByTypeReport.ListedSecurityDisposalProceeds)" Title="Disposal Proceeds" FormatString="{0:C2}" TextAlign="TextAlign.Right" />
                            <RadzenDataGridColumn TItem="TaxYearCgtByTypeReport" Property="@nameof(TaxYearCgtByTypeReport.ListedSecurityAllowableCosts)" Title="Allowable Costs" FormatString="{0:C2}" TextAlign="TextAlign.Right" />
                            <RadzenDataGridColumn TItem="TaxYearCgtByTypeReport" Property="@nameof(TaxYearCgtByTypeReport.ListedSecurityGainExcludeLoss)" Title="Gain Excluding Loss" FormatString="{0:C2}" TextAlign="TextAlign.Right" />
                            <RadzenDataGridColumn TItem="TaxYearCgtByTypeReport" Property="@nameof(TaxYearCgtByTypeReport.ListedSecurityLoss)" Title="Loss" FormatString="{0:C2}" TextAlign="TextAlign.Right" />
                        </Columns>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="TaxYearCgtByTypeReport" Title="Other Assets">
                        <Columns>
                            <RadzenDataGridColumn TItem="TaxYearCgtByTypeReport" Property="@nameof(TaxYearCgtByTypeReport.OtherAssetsNumberOfDisposals)" Title="Number of Disposals" TextAlign="TextAlign.Right" />
                            <RadzenDataGridColumn TItem="TaxYearCgtByTypeReport" Property="@nameof(TaxYearCgtByTypeReport.OtherAssetsDisposalProceeds)" Title="Disposal Proceeds" FormatString="{0:C2}" TextAlign="TextAlign.Right" />
                            <RadzenDataGridColumn TItem="TaxYearCgtByTypeReport" Property="@nameof(TaxYearCgtByTypeReport.OtherAssetsAllowableCosts)" Title="Allowable Costs" FormatString="{0:C2}" TextAlign="TextAlign.Right" />
                            <RadzenDataGridColumn TItem="TaxYearCgtByTypeReport" Property="@nameof(TaxYearCgtByTypeReport.OtherAssetsGainExcludeLoss)" Title="Gain Excluding Loss" FormatString="{0:C2}" TextAlign="TextAlign.Right" />
                            <RadzenDataGridColumn TItem="TaxYearCgtByTypeReport" Property="@nameof(TaxYearCgtByTypeReport.OtherAssetsLoss)" Title="Loss" FormatString="{0:C2}" TextAlign="TextAlign.Right" />
                        </Columns>
                    </RadzenDataGridColumn>
                </Columns>
            </RadzenDataGrid>
        </div>
    </div>
</div>

@code {
    private RadzenDataGrid<TaxYearCgtByTypeReport>? taxYearCgtByTypeReportGrid;
    private List<TaxYearCgtByTypeReport> _taxYearCgtByTypeReports = [];
    private readonly int[] _pageSizeOptions = { 25, 50, 100 };

    protected override void RefreshData()
    {
        _taxYearCgtByTypeReports = _taxYearCgtByTypeReportService.GetTaxYearCgtByTypeReports().ToList();
    }

    protected override Task RefreshRenderedGridsAsync() => RefreshGridAsync(taxYearCgtByTypeReportGrid);
}
