@using Services
@implements IDisposable
@inject ToastService ToastService
@inject NotificationService NotificationService

@* Visual host (RadzenNotification) is provided once by <RadzenComponents /> in MainLayout.
   This component just bridges the app's ToastService events to Radzen notifications. *@

@code {
    protected override void OnInitialized()
    {
        ToastService.ShowToastTrigger += OnShowToast;
        base.OnInitialized();
    }

    private void OnShowToast(ToastOption options)
    {
        InvokeAsync(() =>
        {
            NotificationService.Notify(new NotificationMessage
            {
                Severity = options.Type switch
                {
                    ToastOptionType.Warning => NotificationSeverity.Warning,
                    ToastOptionType.Error => NotificationSeverity.Error,
                    ToastOptionType.Success => NotificationSeverity.Success,
                    ToastOptionType.Info => NotificationSeverity.Info,
                    _ => NotificationSeverity.Info
                },
                Summary = options.Title,
                // Detail is rendered as escaped text; newlines in the content become line
                // breaks via the `white-space: pre-line` rule on .rz-notification-message.
                Detail = options.Content,
                Duration = 5000d
            });
        });
    }

    public void Dispose()
    {
        ToastService.ShowToastTrigger -= OnShowToast;
    }
}
